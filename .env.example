# Copy to .env and fill in. .env is gitignored.

# Path to the Stockfish UCI binary. If unset, the app auto-detects common
# locations (PATH, winget package dir, Homebrew, /usr/bin, ./engines).
# STOCKFISH_PATH=C:\Users\you\AppData\Local\Microsoft\WinGet\Packages\Stockfish.Stockfish_...\stockfish\stockfish-windows-x86-64-avx2.exe

# Engine analysis budget. Use ONE of depth or movetime. Recorded in every report
# so analysis is reproducible.
ENGINE_DEPTH=18
# ENGINE_MOVETIME_MS=500
ENGINE_THREADS=1
ENGINE_HASH_MB=128
ENGINE_MULTIPV=1

# --- Anthropic (only needed from M3 onward) ---
# Never hard-code the key. Find the latest model IDs at https://docs.claude.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
